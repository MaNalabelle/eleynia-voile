# ─────────────────────────────────────────────────────────
#  ELEYNIA — Variables d'environnement
#  Copier ce fichier en .env.local et remplir les valeurs.
#  NE JAMAIS commiter .env.local dans Git.
# ─────────────────────────────────────────────────────────

# Clé API Brevo (Sendinblue)
# Obtenir sur : https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# Identifiant de la liste Brevo (entier)
# Trouver sur : https://app.brevo.com/contact/list
BREVO_LIST_ID=your_list_id_here
